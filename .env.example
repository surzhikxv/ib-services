# Шаблон окружения «Контур роста». Скопируй в .env и заполни.
# .env в git НЕ попадает (см. .gitignore). Реальные креды — только локально/на VPS.

# --- BotHelp Open API ---
# Перевыпуск: BotHelp -> Настройки -> Интеграции -> Open API -> ОБНОВИТЬ
BOTHELP_CLIENT_ID=
BOTHELP_CLIENT_SECRET=
BOTHELP_OAUTH_URL=https://oauth.bothelp.io/oauth2/token
BOTHELP_API_BASE=https://api.bothelp.io
BOTHELP_BOT_REFERRAL=

# --- База данных ---
# Боевая (docker-compose) — Postgres. Для локальной проверки можно не задавать
# DATABASE_URL: тогда возьмётся файловый SQLite (data/kontur.sqlite).
POSTGRES_USER=kontur
POSTGRES_PASSWORD=change_me
POSTGRES_DB=kontur
# DATABASE_URL=postgresql+psycopg://kontur:change_me@postgres:5432/kontur

# --- n8n (оркестратор) ---
N8N_USER=admin
N8N_PASSWORD=change_me
TZ=Europe/Moscow

# --- LLM (заполнить при сборке ИИ-слоя, Phase 1 п.4) ---
LLM_API_KEY=
