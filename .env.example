# Шаблон окружения «Контур роста». Скопируй в .env и заполни.
# .env в git НЕ попадает (см. .gitignore). Реальные креды — только локально/на VPS.

# --- База данных ---
# Боевая (docker-compose) — Postgres. Для локальной проверки можно не задавать
# DATABASE_URL: тогда возьмётся файловый SQLite (data/kontur.sqlite).
POSTGRES_USER=kontur
POSTGRES_PASSWORD=change_me
POSTGRES_DB=kontur
# DATABASE_URL=postgresql+psycopg://kontur:change_me@postgres:5432/kontur

# --- n8n (оркестратор) ---
N8N_USER=admin
N8N_PASSWORD=change_me
TZ=Europe/Moscow

# --- Metabase (дашборд) ---
# Заполнить ПОСЛЕ первого входа в Metabase (мастер создаёт админа),
# затем: docker compose run --rm app python -m kontur.cli metabase provision
METABASE_URL=http://metabase:3000
METABASE_USER=
METABASE_PASSWORD=
# Отдельная read-only роль источника данных Metabase. Не используй POSTGRES_USER.
METABASE_DB_USER=metabase_ro
METABASE_DB_PASSWORD=

# --- LLM (ИИ-аналитик, Phase 1 п.4) ---
# Свой ключ Anthropic (аккаунт thedialog.kz — KZ поддерживается, прямой биллинг).
LLM_API_KEY=
LLM_MODEL=claude-opus-4-8
LLM_EFFORT=medium
# Форвард-прокси вне РФ (Hetzner): api.anthropic.com из РФ заблокирован.
# Только вызов модели идёт через прокси; данные/БД остаются на РФ-сервере.
# Сквозной TLS (CONNECT) — прокси видит только шифротекст. Локально/в KZ можно оставить пустым.
# LLM_PROXY_URL=http://user:pass@RELAY_IP:3128
LLM_PROXY_URL=

# --- Telegram-бот владельца (доставка разборов; каркас) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Куда присылать ошибки/застой коннекторов. Если пусто, монитор пишет только в journald.
SYNC_ALERT_CHAT_ID=
# 1 = присылать также успешный сводный запуск; по умолчанию только проблемы.
SYNC_ALERT_ON_SUCCESS=0
# Прокси для Telegram (на dev-машине; на сервере не нужен). Берётся и из ALL_PROXY/HTTPS_PROXY.
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

# --- Prodamus (приём оплат воронки бота, пакет bot/) ---
# Магазин: <домен>.payform.ru + секретный ключ (Prodamus -> Настройки -> Интеграции).
PRODAMUS_DOMAIN=
PRODAMUS_SECRET=
# Публичный адрес приёма вебхука (домен или туннель cloudflared/ngrok), без слэша на конце.
PUBLIC_BASE_URL=
PRODAMUS_WEBHOOK_PORT=8081
# Подписывать исходящие ссылки (защита цены от подмены в URL): 1 — включить.
PRODAMUS_SIGN_LINKS=
# Куда вернуть человека после оплаты в браузере (например, ссылка на бота).
PAYMENT_RETURN_URL=
# chat_id каналов для лучшего UX после оплаты: бот должен быть админом канала.
# Если задать эти id, бот сам выдаст персональную одноразовую кнопку «Войти в канал».
CHANNEL_BASIC_ID=
CHANNEL_STANDARD_ID=
CHANNEL_PREMIUM_ID=

# --- Напоминания неоплатившим ---
# Каждые 48 часов бот шлёт один из трёх случайных текстов тем, кто
# запустил бота, но не оплатил курс. Кнопка ведёт на выбор тарифа.
BOT_REMINDERS_ENABLED=1
BOT_REMINDER_INTERVAL_HOURS=48
BOT_REMINDER_POLL_SECONDS=300
BOT_REMINDER_BATCH_SIZE=100

# --- Медиа собственной Telegram-воронки ---
# Runtime-файлы лежат в media/ и едут на сервер вместе с image.
# Каталог по умолчанию — media/ рядом с проектом; можно сменить:
# BOT_MEDIA_DIR=/opt/kontur/media
# Либо указать конкретный файл напрямую (важнее каталога):
# WELCOME_VIDEO_PATH=/opt/kontur/media/welcome.mp4
# Файла нет на сервере → бот аккуратно покажет заглушку «будет добавлено», не упадёт.
# Пути bind-mount для Compose (на VPS обычно оставляются значениями по умолчанию):
# KONTUR_MEDIA_DIR=./media

# --- Коннектор ВКонтакте ---
# VK — РФ-родной, ходим напрямую (без релея). Нужен ОДИН user-токен админа:
# community-токен сообщества не умеет wall.get. Как достать — docs/connectors/vk-access.md.
VK_GROUP_ID=                 # числовой id сообщества (без минуса)
VK_USER_STATS_TOKEN=         # user-токен админа: посты + охваты + статистика (scope stats,offline)
# Необязательно (значения по умолчанию):
# VK_API_BASE=https://api.vk.com/method   # после ~30.09.2026 возможен переезд на .vk.ru
# VK_API_VERSION=5.199

# --- Коннектор TikTok (ингест файлов из браузера, B+) ---
# API органику не отдаёт → данные снимает userscript/расширение из залогиненного
# TikTok Studio и шлёт на POST /ingest/tiktok. Токен защищает эндпоинт от чужих.
# Как снять и залить — docs/connectors/tiktok-access.md. Сгенерируй случайный:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TIKTOK_INGEST_TOKEN=

# --- Общий приём сырых webhook-событий ---
# Endpoint /webhooks/{source} выключен, пока токен пуст. Отдельный Prodamus webhook
# живёт в bot/ и использует собственную HMAC-подпись.
WEBHOOK_INGEST_TOKEN=
WEBHOOK_ALLOWED_SOURCES=

# --- YouTube (Data API v3 по ключу + Analytics API по OAuth владельца) ---
YT_API_KEY=
YT_CHANNEL_ID=
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
# YT_PROXY_URL=http://kontur:PASS@RELAY_IP:3128   # релей вне РФ (Google заблокирован)

# --- Instagram / Meta ---
# instagram = Instagram Login (graph.instagram.com, проще, без Facebook Page)
# facebook  = Facebook Login (graph.facebook.com, максимум данных при привязанной Facebook Page)
INSTAGRAM_AUTH_MODE=instagram
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
# Для INSTAGRAM_AUTH_MODE=facebook: Facebook Page с привязанным Instagram Business/Creator.
INSTAGRAM_PAGE_ID=
# INSTAGRAM_API_BASE=https://graph.facebook.com
# INSTAGRAM_API_VERSION=v25.0
# INSTAGRAM_TIMEZONE=Europe/Moscow
# Релей вне РФ (Meta заблокирована).
IG_PROXY_URL=

# --- Telegram-каналы (MTProto/Telethon user session) ---
# Нужен отдельный компанейский Telegram-аккаунт, добавленный админом каналов.
# TG_SESSION хранить как пароль. TG_PHONE нужен только для bootstrap-session.
TG_API_ID=
TG_API_HASH=
TG_SESSION=
# TG_PHONE=+79990000000
TELEGRAM_CHANNEL_IDS=@slapychev
# Либо один канал:
# TELEGRAM_CHANNEL_ID=@slapychev
# Если MTProto с VPS таймаутится, Telethon берёт TG_PROXY_URL,
# а при его отсутствии переиспользует YT_PROXY_URL/IG_PROXY_URL.
# TG_PROXY_URL=http://kontur:PASS@RELAY_IP:3128
