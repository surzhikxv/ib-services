.DS_Store
.env
.env.*
!.env.example
__pycache__/
*.pyc
.venv/
venv/
data/
*.sqlite
*.sqlite3
.pytest_cache/
*.egg-info/
build/
dist/
*.docx
~$*

# внутренние документы для клиента (бриф, КП, генераторы) — не часть кода системы
HANDOFF.md
build_*.py

# сырьё из BotHelp и производная выгрузка контента шагов — данные клиента, не в гит
raw/

# медиа воронки, которых нет в публичной выгрузке BotHelp. Видео-приветствие
# (welcome.mp4) коммитим — это часть контента воронки, едет на сервер вместе с кодом.
# Прочие медиа-файлы клиента не трекаем (можно подключить через .env: BOT_MEDIA_DIR / *_PATH).
media/*
!media/welcome.mp4
